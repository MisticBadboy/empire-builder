{
  "expo": {
    "name": "Empire Builder",
    "slug": "empire-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.empirebuilder.tycoon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1117"
      },
      "package": "com.empirebuilder.tycoon",
      "googleMobileAdsAppId": "ca-app-pub-6751661713322837~6564626077"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "android_app_id": "ca-app-pub-6751661713322837~6564626077",
          "ios_app_id": "",
          "user_tracking_usage_description": "This identifier will be used to deliver personalized ads to you.",
          "sk_ad_network_items": []
        }
      ]
    ],
    "scheme": "empire-builder"
  }
}
